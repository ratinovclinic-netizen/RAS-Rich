# Server-only secret. Never expose this value in client-side code or commit a real URL.
BITRIX24_WEBHOOK_URL=https://your-portal.bitrix24.example/rest/USER_ID/WEBHOOK_TOKEN/
BITRIX24_CATEGORY_IDS=144,152,58,86,142,154

# Read-only Google service account. Share the spreadsheet with this email as Viewer.
GOOGLE_SERVICE_ACCOUNT_EMAIL=agent-reader@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# Bot created through @BotFather and the private Telegram chat receiving reports.
TELEGRAM_BOT_TOKEN=123456:REPLACE_ME
TELEGRAM_CHAT_ID=123456789

# Protects scheduler calls to POST /api/investment-agent/run.
AGENT_CRON_SECRET=replace-with-a-long-random-value

# Map real Bitrix stages and Google ranges without changing application code.
INVESTMENT_AGENT_CONFIG_JSON={"timezone":"Asia/Bishkek","currency":"USD","bitrix":{"entityTypeId":2,"categoryIds":[0],"wonStageIds":["WON"],"lostStageIds":["LOSE"]},"google":{"spreadsheetId":"REPLACE_ME","ranges":["Payments!A1:Z"],"amountColumnIndex":4}}
